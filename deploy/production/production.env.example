# postgres container
POSTGRES_DB=openlog
POSTGRES_USER=openlog
POSTGRES_PASSWORD=change-me

# backend datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/openlog
SPRING_DATASOURCE_USERNAME=openlog
SPRING_DATASOURCE_PASSWORD=change-me

# redis
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# flyway
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=20260324

# oauth
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URI=https://your-domain/api/auth/google/callback

# jwt
AUTH_JWT_SECRET=change-me
AUTH_JWT_ISSUER=openlog
AUTH_JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
AUTH_JWT_COOKIE_NAME=openlog_access_token
AUTH_JWT_COOKIE_SECURE=true
AUTH_JWT_COOKIE_DOMAIN=.openlog.kr

# app
APP_FRONTEND_HOME_URL=https://your-frontend-domain
SERVER_SERVLET_CONTEXT_PATH=/api
SERVER_PORT=8080
JAVA_OPTS=-Xms256m -Xmx512m

# nginx
NGINX_SERVER_NAME=api.openlog.kr
NGINX_SSL_CERTIFICATE=/etc/nginx/certs/api.openlog.kr.pem
NGINX_SSL_CERTIFICATE_KEY=/etc/nginx/certs/api.openlog.kr.key

# image tag written by CD
BACKEND_IMAGE=ghcr.io/owner/repo/backend:production
